---
import PageLayout from '../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout
  title="Contact UKF Services | Get a Freight Quote in 24 Hours"
  description="Contact UKF Services for freight quotes and logistics enquiries. Call +971 55 257 2837 or visit Dubai Cargo Village. Same-day response guaranteed. Zero hidden fees."
>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="container contact-hero-inner">
      <div class="contact-hero-content fade-up">
        <p class="eyebrow">Get In Touch</p>
        <h1 class="contact-title">Let's Move Your Cargo.</h1>
        <p class="contact-subtitle">Same-day response on all enquiries. Fully itemised quotes. No hidden fees. No obligation.</p>
        <div class="contact-quick">
          <a href="tel:+971552572837" class="quick-item">
            <div class="quick-icon">📞</div>
            <div>
              <span class="quick-label">Call us</span>
              <span class="quick-value">+971 55 257 2837</span>
            </div>
          </a>
          <a href="https://wa.me/971552572837" target="_blank" rel="noopener" class="quick-item quick-item--wa">
            <div class="quick-icon">💬</div>
            <div>
              <span class="quick-label">WhatsApp</span>
              <span class="quick-value">+971 55 257 2837</span>
            </div>
          </a>
          <a href="mailto:info@ukfservices.com" class="quick-item">
            <div class="quick-icon">✉</div>
            <div>
              <span class="quick-label">Email us</span>
              <span class="quick-value">info@ukfservices.com</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <div class="contact-body">
    <div class="container contact-grid">

      <!-- FORM -->
      <div class="contact-form-wrap fade-up">
        <div class="form-header">
          <h2>Send Us Your Enquiry</h2>
          <p>Complete the form and we'll respond within 24 hours with a tailored freight quote.</p>
        </div>

        <form class="contact-form" action="https://formspree.io/f/xzdpekbl" method="POST" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name <span class="required">*</span></label>
              <input type="text" id="name" name="name" placeholder="Ahmed Al Mansouri" required />
            </div>
            <div class="form-group">
              <label for="company">Company Name</label>
              <input type="text" id="company" name="company" placeholder="Trading LLC" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email Address <span class="required">*</span></label>
              <input type="email" id="email" name="email" placeholder="ahmed@company.com" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone / WhatsApp</label>
              <input type="tel" id="phone" name="phone" placeholder="+971 XX XXX XXXX" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="service">Service Required</label>
              <select id="service" name="service">
                <option value="">Select a service...</option>
                <option>Air Freight</option>
                <option>Sea Freight (FCL)</option>
                <option>Sea Freight (LCL)</option>
                <option>Customs Clearance</option>
                <option>Land Transport</option>
                <option>Warehousing</option>
                <option>Project Cargo</option>
                <option>Multiple Services</option>
              </select>
            </div>
            <div class="form-group">
              <label for="urgency">Timeline</label>
              <select id="urgency" name="urgency">
                <option value="">Select timeline...</option>
                <option>Urgent — within 48 hours</option>
                <option>This week</option>
                <option>Within a month</option>
                <option>Planning ahead</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="origin">Origin</label>
              <input type="text" id="origin" name="origin" placeholder="e.g. Dubai, UAE" />
            </div>
            <div class="form-group">
              <label for="destination">Destination</label>
              <input type="text" id="destination" name="destination" placeholder="e.g. London, UK" />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Shipment Details <span class="required">*</span></label>
            <textarea id="message" name="message" rows="4" placeholder="Cargo type, weight/volume, any special requirements (temperature control, hazardous, high-value)..." required></textarea>
          </div>
          <button type="submit" class="form-submit" id="form-submit">
            <span id="submit-text">Send Enquiry</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
          </button>
          <p class="form-note">We respond within 24 hours. Your details are never shared or sold.</p>
        </form>

        <!-- Success message -->
        <div id="form-success" class="form-success" style="display:none;">
          <div class="success-icon">✓</div>
          <h3>Enquiry Received</h3>
          <p>Thank you — we'll respond within 24 hours with a tailored quote. For urgent shipments, call us directly on <a href="tel:+971552572837">+971 55 257 2837</a> or <a href="https://wa.me/971552572837" target="_blank">WhatsApp us</a>.</p>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="contact-sidebar">

        <!-- Office Info -->
        <div class="sidebar-card fade-up">
          <h3 class="sidebar-card-title">Dubai Cargo Village Office</h3>
          <div class="office-details">
            <div class="office-item">
              <span class="office-icon">📍</span>
              <div>
                <strong>Address</strong>
                <p>Office No. 2056-A, First Floor<br/>Entrance No. 4, Dubai Cargo Village<br/>Dubai, UAE</p>
              </div>
            </div>
            <div class="office-item">
              <span class="office-icon">📞</span>
              <div>
                <strong>Phone</strong>
                <p><a href="tel:+971552572837">+971 55 257 2837</a></p>
              </div>
            </div>
            <div class="office-item">
              <span class="office-icon">💬</span>
              <div>
                <strong>WhatsApp</strong>
                <p><a href="https://wa.me/971552572837" target="_blank" rel="noopener">+971 55 257 2837</a></p>
              </div>
            </div>
            <div class="office-item">
              <span class="office-icon">✉</span>
              <div>
                <strong>Email</strong>
                <p><a href="mailto:info@ukfservices.com">info@ukfservices.com</a></p>
              </div>
            </div>
            <div class="office-item">
              <span class="office-icon">🕐</span>
              <div>
                <strong>Office Hours</strong>
                <p>Sunday–Thursday<br/>08:00–18:00 GST</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Response Guarantee -->
        <div class="sidebar-card sidebar-card--navy fade-up">
          <h3 class="sidebar-card-title" style="color:var(--gold)">Our Response Guarantee</h3>
          <div class="guarantee-items">
            <div class="guarantee-item">
              <span class="guarantee-check">✓</span>
              <p><strong>Same-day response</strong> for enquiries received before 4PM GST</p>
            </div>
            <div class="guarantee-item">
              <span class="guarantee-check">✓</span>
              <p><strong>Fully itemised quote</strong> — no hidden fees, ever</p>
            </div>
            <div class="guarantee-item">
              <span class="guarantee-check">✓</span>
              <p><strong>No obligation</strong> — you decide if you want to proceed</p>
            </div>
            <div class="guarantee-item">
              <span class="guarantee-check">✓</span>
              <p><strong>Specialist advice</strong> — not a call centre, a freight expert</p>
            </div>
          </div>
          <a href="https://wa.me/971552572837?text=Hello%20UKF%2C%20I%27d%20like%20a%20freight%20quote." target="_blank" rel="noopener" class="wa-direct-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp for Urgent Shipments
          </a>
        </div>

        <!-- What to expect -->
        <div class="sidebar-card fade-up">
          <h3 class="sidebar-card-title">What Happens Next</h3>
          <div class="next-steps">
            <div class="next-step">
              <span class="next-num">01</span>
              <div>
                <strong>We review your enquiry</strong>
                <p>A freight specialist reviews your shipment details and requirements.</p>
              </div>
            </div>
            <div class="next-step">
              <span class="next-num">02</span>
              <div>
                <strong>We prepare your quote</strong>
                <p>Fully itemised — carrier options, transit times, all-in costs.</p>
              </div>
            </div>
            <div class="next-step">
              <span class="next-num">03</span>
              <div>
                <strong>We follow up directly</strong>
                <p>Your specialist contacts you to discuss and answer questions.</p>
              </div>
            </div>
          </div>
        </div>

      </aside>
    </div>
  </div>

  <script is:inline>
    var form = document.getElementById('contact-form');
    var success = document.getElementById('form-success');
    var submitBtn = document.getElementById('form-submit');
    var submitText = document.getElementById('submit-text');

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        submitBtn.disabled = true;
        submitText.textContent = 'Sending...';

        fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        }).then(function(res) {
          if (res.ok) {
            form.style.display = 'none';
            success.style.display = 'block';
            if (typeof gtag !== 'undefined') {
              gtag('event', 'contact_form_submit', { event_category: 'Lead Generation' });
            }
          } else {
            submitText.textContent = 'Send Enquiry';
            submitBtn.disabled = false;
            alert('Something went wrong. Please try again or contact us directly.');
          }
        }).catch(function() {
          submitText.textContent = 'Send Enquiry';
          submitBtn.disabled = false;
          alert('Something went wrong. Please try again or contact us directly.');
        });
      });
    }
  </script>

  <!-- JSON-LD -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact UKF Services",
    "description": "Get in touch with UKF Services for freight forwarding and logistics enquiries",
    "mainEntity": {
      "@type": "Organization",
      "name": "UKF Services",
      "telephone": "+971-55-257-2837",
      "email": "info@ukfservices.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Office No. 2056-A, First Floor, Entrance No. 4, Dubai Cargo Village",
        "addressLocality": "Dubai",
        "addressCountry": "AE"
      }
    }
  })}</script>

</PageLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }

  /* HERO */
  .contact-hero {
    background: linear-gradient(135deg, var(--navy) 0%, #0f2a50 100%);
    padding: 100px 0 64px;
    border-bottom: 1px solid rgba(201,168,76,0.15);
    text-align: center;
  }
  .contact-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 800;
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .contact-subtitle {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 40px;
  }
 .contact-quick {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .quick-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 14px 20px;
    transition: background 0.2s, border-color 0.2s;
    text-decoration: none;
  }
  .quick-item:hover { background: rgba(255,255,255,0.1); border-color: rgba(201,168,76,0.3); }
  .quick-item--wa { border-color: rgba(37,211,102,0.3); }
  .quick-item--wa:hover { background: rgba(37,211,102,0.1); border-color: rgba(37,211,102,0.5); }
  .quick-icon { font-size: 22px; }
  .quick-label { display: block; font-size: 11px; color: rgba(255,255,255,0.45); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 2px; }
  .quick-value { display: block; font-size: 14px; font-weight: 600; color: var(--white); }

  /* BODY */
  .contact-body { padding: 64px 0 80px; background: var(--gray-100); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 1024px) { .contact-grid { grid-template-columns: 1fr; } }

  /* FORM */
  .contact-form-wrap {
    background: var(--white);
    border-radius: 16px;
    padding: 40px;
    border: 1px solid var(--gray-200);
  }
  .form-header { margin-bottom: 32px; }
  .form-header h2 {
    font-family: var(--font-heading);
    font-size: 26px;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .form-header p { font-size: 14px; color: var(--gray-600); line-height: 1.6; }

  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label {
    font-size: 12px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .required { color: var(--red); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text);
    border: 1.5px solid var(--gray-200);
    border-radius: 8px;
    padding: 11px 14px;
    background: var(--white);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
  }
  .form-group textarea { resize: vertical; min-height: 110px; }
  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    padding: 15px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    width: 100%;
  }
  .form-submit:hover { background: var(--gold); color: var(--navy); transform: translateY(-1px); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .form-note { font-size: 12px; color: var(--gray-400); text-align: center; }

  .form-success {
    text-align: center;
    padding: 48px 24px;
  }
  .success-icon {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #10b981;
    color: #fff;
    font-size: 28px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
  }
  .form-success h3 { font-family: var(--font-heading); font-size: 24px; color: var(--navy); margin-bottom: 12px; }
  .form-success p { font-size: 15px; color: var(--gray-600); line-height: 1.7; }
  .form-success a { color: var(--gold); font-weight: 600; }

  /* SIDEBAR */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 100px;
  }
  .sidebar-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 16px;
    padding: 28px;
  }
  .sidebar-card--navy {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    border-color: rgba(201,168,76,0.2);
  }
  .sidebar-card-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .office-details { display: flex; flex-direction: column; gap: 16px; }
  .office-item { display: flex; gap: 12px; align-items: flex-start; }
  .office-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
  .office-item strong { display: block; font-size: 12px; font-weight: 700; color: var(--navy); margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
  .office-item p { font-size: 13px; color: var(--gray-600); line-height: 1.5; margin: 0; }
  .office-item a { color: var(--navy); transition: color 0.2s; }
  .office-item a:hover { color: var(--gold); }

  .guarantee-items { display: flex; flex-direction: column; gap: 14px; margin-bottom: 24px; }
  .guarantee-item { display: flex; gap: 12px; align-items: flex-start; }
  .guarantee-check {
    width: 20px; height: 20px;
    border-radius: 50%;
    background: rgba(201,168,76,0.2);
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .guarantee-item p { font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.5; margin: 0; }
  .guarantee-item strong { color: var(--white); }
  .wa-direct-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 13px 20px;
    border-radius: 8px;
    width: 100%;
    transition: opacity 0.2s;
  }
  .wa-direct-btn:hover { opacity: 0.9; }

  .next-steps { display: flex; flex-direction: column; gap: 20px; }
  .next-step { display: flex; gap: 16px; align-items: flex-start; }
  .next-num {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--gray-200);
    line-height: 1;
    flex-shrink: 0;
    width: 32px;
  }
  .next-step strong { display: block; font-size: 14px; color: var(--navy); margin-bottom: 4px; }
  .next-step p { font-size: 13px; color: var(--gray-600); line-height: 1.5; margin: 0; }
</style>
