---
import PageLayout from '../layouts/PageLayout.astro';
export const prerender = false;

const services = [
  {
    icon: '✈',
    title: 'Air Freight',
    slug: 'air-freight',
    description: 'Fast, controlled air cargo from Dubai Cargo Village to 200+ global destinations. Priority, express, and standard services for time-sensitive, high-value, and perishable shipments. Direct carrier relationships with Emirates SkyCargo, Etihad Cargo, and all major airlines.'
  },
  {
    icon: '🚢',
    title: 'Ocean Freight',
    slug: 'ocean-freight',
    description: 'Full Container Load (FCL) and Less than Container Load (LCL) services from Jebel Ali to all major global ports. Cost-effective solutions for bulk cargo, with weekly sailings on all key trade lanes including China, Europe, USA, and GCC.'
  },
  {
    icon: '📋',
    title: 'Customs Clearance',
    slug: 'customs-clearance',
    featured: true,
    description: 'Licensed customs brokers based at Dubai Cargo Village and Jebel Ali. 100% compliance record across all client shipments. We handle HS code classification, duty assessment, Dubai Trade portal declarations, and all documentation for imports and exports.'
  },
  {
    icon: '🚛',
    title: 'Road Freight',
    slug: 'road-freight',
    description: 'Flexible and efficient road freight solutions within the UAE and across the GCC. Full Truck Load (FTL) and Less than Truck Load (LTL) options. GPS-tracked vehicles, experienced drivers, and direct door-to-door delivery reducing handling time and cargo damage risk.'
  },
  {
    icon: '🛣',
    title: 'Cross-Border Road Services',
    slug: 'cross-border',
    description: 'Seamless cross-border road freight across GCC international borders. Pre-prepared customs documentation ensures drivers arrive at border crossings with everything in order. Regular services to Saudi Arabia, Oman, Kuwait, Qatar, and Bahrain.'
  },
  {
    icon: '🤝',
    title: 'Incoterms Advisory',
    slug: 'incoterms',
    description: 'Expert guidance on Incoterms selection and management for UAE importers and exporters. We manage shipments under EXW, DDP, DDU, FOB, DAP, and C&F — ensuring the right terms are applied for each trade lane, supplier relationship, and risk profile.'
  },
];
---

<PageLayout
  title="Our Services | Air, Sea Freight & Customs | UKF Services Dubai"
  description="Comprehensive freight forwarding services in Dubai: Air cargo, ocean freight (FCL/LCL), customs clearance, road freight, cross-border and Incoterms advisory. Serving 200+ UAE exporters since 2008."
>

  <!-- HERO -->
  <section class="services-hero">
    <div class="container services-hero-inner">
      <p class="eyebrow">What We Do</p>
      <h1 class="services-title">Comprehensive Logistics Services.</h1>
      <p class="services-subtitle">A seamless portfolio of services covering every mode of transport and complexity — from Dubai Cargo Village to the world.</p>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="pillars-section fade-up">
    <div class="container">
      <div class="section-header-centered">
        <p class="eyebrow">The UKF Advantage</p>
        <h2 class="pillars-title">Three Pillars of Excellence</h2>
        <p class="pillars-subtitle">We build resilient supply chains through integrated service, dedicated partnership, and absolute compliance.</p>
      </div>
      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-icon">📦</div>
          <h3>Integrated Solutions</h3>
          <p>From air and sea freight to customs clearance and cross-border road transport, we manage every layer of your logistics as a single, cohesive operation.</p>
          <span class="pillar-tag">END-TO-END</span>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">🤵</div>
          <h3>Dedicated Partnership</h3>
          <p>You receive a senior-level logistics expert as your single point of contact — no call centres, no ticket systems, no excuses.</p>
          <span class="pillar-tag">ELITE SERVICE</span>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">🛡</div>
          <h3>100% Compliance</h3>
          <p>Our licensed customs brokers at Dubai Cargo Village maintain a 100% UAE customs compliance record across all client shipments since 2008.</p>
          <span class="pillar-tag">ZERO SURPRISES</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="services-list-section">
    <div class="container">
      <div class="section-header-centered fade-up">
        <p class="eyebrow">Our Portfolio</p>
        <h2 class="pillars-title">Our Complete Service Portfolio</h2>
        <p class="pillars-subtitle">Six specialist services covering every freight requirement for UAE importers and exporters.</p>
      </div>

      <div class="services-grid">
        {services.map((service) => (
          <a href={`/services/${service.slug}`} class={`service-card ${service.featured ? 'service-card--featured' : ''}`}>
            {service.featured && <div class="service-card-badge">100% Compliance</div>}
            <div class="service-card-icon">{service.icon}</div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <span class="service-card-link">Explore {service.title} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta-section fade-up">
    <div class="container services-cta-inner">
      <div>
        <h2>Not sure which service you need?</h2>
        <p>Tell us about your cargo — we'll recommend the right solution.</p>
      </div>
      <div class="services-cta-btns">
        <a href="/contact" class="services-cta-primary">Get a Free Quote</a>
        <a href="https://wa.me/971552572837" target="_blank" rel="noopener" class="services-cta-wa">WhatsApp Us</a>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "UKF Services - Freight & Logistics Services",
    "description": "Comprehensive freight forwarding and logistics services offered by UKF Services in Dubai",
    "itemListElement": services.map((s, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Service",
        "name": s.title,
        "description": s.description,
        "url": `https://ukfservices.com/services/${s.slug}`,
        "provider": { "@type": "Organization", "name": "UKF Services" }
      }
    }))
  })}</script>

</PageLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }
  .section-header-centered { text-align: center; margin-bottom: 56px; }

  /* HERO */
  .services-hero {
    background: linear-gradient(135deg, var(--navy) 0%, #0f2a50 100%);
    padding: 100px 0 72px;
    text-align: center;
  }
  .services-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .services-subtitle {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* PILLARS */
  .pillars-section { padding: 80px 0; background: var(--white); }
  .pillars-title {
    font-family: var(--font-heading);
    font-size: clamp(26px, 3.5vw, 38px);
    color: var(--navy);
    margin-bottom: 16px;
  }
  .pillars-subtitle {
    font-size: 15px;
    color: var(--gray-600);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 900px) { .pillars-grid { grid-template-columns: 1fr; } }
  .pillar-card {
    background: var(--off-white);
    border: 1px solid var(--gray-200);
    border-radius: 14px;
    padding: 36px 30px;
    text-align: center;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .pillar-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(10,22,40,0.08); }
  .pillar-icon { font-size: 36px; margin-bottom: 16px; }
  .pillar-card h3 {
    font-family: var(--font-heading);
    font-size: 19px;
    color: var(--navy);
    margin-bottom: 12px;
  }
  .pillar-card p { font-size: 14px; color: var(--gray-600); line-height: 1.7; margin-bottom: 16px; }
  .pillar-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    background: rgba(201,168,76,0.06);
    padding: 4px 12px;
    border-radius: 20px;
  }

  /* SERVICES GRID */
  .services-list-section { padding: 80px 0; background: var(--off-white); border-top: 1px solid var(--gray-200); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .services-grid { grid-template-columns: 1fr; } }

  .service-card {
    background: var(--white);
    border-radius: 14px;
    padding: 36px 30px;
    border: 1px solid var(--gray-200);
    border-top: 4px solid var(--gold);
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;
    text-decoration: none;
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(201,168,76,0.15);
  }
  .service-card--featured {
    background: linear-gradient(135deg, #fffdf5 0%, #fff 100%);
  }
  .service-card-badge {
    position: absolute;
    top: -12px;
    left: 30px;
    background: var(--gold);
    color: var(--navy);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
  }
  .service-card-icon {
    width: 56px; height: 56px;
    background: rgba(201,168,76,0.1);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
  }
  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 21px;
    color: var(--navy);
    margin-bottom: 12px;
  }
  .service-card p {
    color: var(--gray-600);
    font-size: 14px;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 24px;
  }
  .service-card-link {
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
    transition: color 0.2s;
  }
  .service-card:hover .service-card-link { color: var(--navy); }

  /* CTA */
  .services-cta-section {
    background: linear-gradient(135deg, var(--navy) 0%, #0f2a50 100%);
    padding: 64px 0;
    border-top: 1px solid rgba(201,168,76,0.2);
  }
  .services-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .services-cta-inner h2 {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 32px);
    color: var(--white);
    margin-bottom: 8px;
  }
  .services-cta-inner p { font-size: 15px; color: rgba(255,255,255,0.6); }
  .services-cta-btns { display: flex; gap: 16px; flex-wrap: wrap; flex-shrink: 0; }
  .services-cta-primary {
    background: var(--gold);
    color: var(--navy);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    padding: 13px 28px;
    border-radius: 6px;
    transition: background 0.2s, transform 0.2s;
  }
  .services-cta-primary:hover { background: var(--gold-light); transform: translateY(-1px); }
  .services-cta-wa {
    background: #25D366;
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 13px 28px;
    border-radius: 6px;
    transition: opacity 0.2s, transform 0.2s;
  }
  .services-cta-wa:hover { opacity: 0.9; transform: translateY(-1px); }
</style>
