---
import PageLayout from '../layouts/PageLayout.astro';
import { env } from 'cloudflare:workers';
export const prerender = false;

let latestArticles: any[] = [];
let testimonials: any[] = [];

try {
  const db = env.ukf_insights_db as unknown as D1Database;
  const arts = await db.prepare(
    'SELECT title, slug, excerpt, category, image_url, read_time, published_date FROM articles ORDER BY published_date DESC LIMIT 3'
  ).all();
  latestArticles = arts.results || [];

  const testy = await db.prepare(
    'SELECT client_name, company_name, role, sector, quote_short, initials, rating FROM testimonials WHERE active = 1 ORDER BY sort_order ASC LIMIT 3'
  ).all();
  testimonials = testy.results || [];
} catch (e) {}

function getCategoryColor(cat: string) {
  const map: Record<string, string> = {
    'Air Freight': '#3b82f6',
    'Sea Freight': '#0ea5e9',
    'Customs': '#8b5cf6',
    'Trade Corridors': '#10b981',
    'Market Intelligence': '#f59e0b',
    'Cargo Journeys': '#e63946',
    'Indonesia': '#10b981',
  };
  return map[cat] || '#c9a84c';
}

function formatDate(d: string) {
  try { return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }); }
  catch { return d; }
}
