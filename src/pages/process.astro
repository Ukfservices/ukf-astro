---
import PageLayout from '../layouts/PageLayout.astro';
export const prerender = false;
---

<PageLayout
  title="Our Process | Hassle-Free Freight Forwarding | UKF Services"
  description="Transparent 4-step freight forwarding process from consultation to delivery. 100% UAE customs compliance. Zero surprises. Same-day response guaranteed."
>

  <!-- HERO -->
  <section class="process-hero">
    <div class="container process-hero-inner">
      <p class="eyebrow">How We Work</p>
      <h1 class="process-title">No Surprises.<br/>Just Results.</h1>
      <p class="process-subtitle">Every UKF shipment follows the same proven process — built over 17 years at Dubai Cargo Village. You always know exactly where your cargo is and what happens next.</p>
      <div class="process-hero-proof">
        <span>✓ 100% UAE customs compliance</span>
        <span>✓ Same-day quote response</span>
        <span>✓ Single point of contact</span>
        <span>✓ Zero hidden fees</span>
      </div>
    </div>
  </section>

  <!-- PROCESS STEPS -->
  <section class="steps-section">
    <div class="container">

      <div class="steps-intro fade-up">
        <p class="eyebrow">The 4-Step Process</p>
        <h2 class="steps-title">From First Contact to Final Delivery.</h2>
        <p class="steps-subtitle">Whether you're moving a single pallet or a full container, every shipment goes through the same rigorous process — ensuring nothing is missed and nothing goes wrong.</p>
      </div>

      <div class="steps-grid">

        <!-- Step 1 -->
        <div class="step-card fade-up">
          <div class="step-number">01</div>
          <div class="step-icon">💬</div>
          <div class="step-content">
            <h3>Initial Consultation</h3>
            <p class="step-time">Same day · Free · No obligation</p>
            <p class="step-desc">We start by understanding your shipment in detail — cargo type, origin, destination, timeline, weight, volume, and any special requirements. This isn't a form. It's a conversation with a freight specialist.</p>
            <ul class="step-list">
              <li>Cargo assessment and HS code verification</li>
              <li>Mode recommendation — air vs sea vs road</li>
              <li>Timeline and budget alignment</li>
              <li>Regulatory requirements identified upfront</li>
              <li>Fully itemised quote — no hidden costs</li>
            </ul>
            <div class="step-guarantee">
              <span class="guarantee-tag">⏱ Response within 24 hours</span>
            </div>
          </div>
        </div>

        <div class="step-connector fade-up">
          <div class="connector-line"></div>
          <div class="connector-arrow">↓</div>
        </div>

        <!-- Step 2 -->
        <div class="step-card fade-up">
          <div class="step-number">02</div>
          <div class="step-icon">🗺</div>
          <div class="step-content">
            <h3>Route Planning & Booking</h3>
            <p class="step-time">24–48 hours · All bookings handled</p>
            <p class="step-desc">Once you approve the quote, we design the optimal route and handle every booking. Carrier selection, slot allocation, documentation preparation — all managed by your dedicated specialist.</p>
            <ul class="step-list">
              <li>Carrier selection — Emirates SkyCargo, MSC, CMA CGM and more</li>
              <li>Slot booking and confirmation</li>
              <li>Export documentation prepared and verified</li>
              <li>UAE Customs export declaration filed</li>
              <li>Insurance arranged if required</li>
            </ul>
            <div class="step-guarantee">
              <span class="guarantee-tag">📋 All documentation verified before submission</span>
            </div>
          </div>
        </div>

        <div class="step-connector fade-up">
          <div class="connector-line"></div>
          <div class="connector-arrow">↓</div>
        </div>

        <!-- Step 3 -->
        <div class="step-card step-card--featured fade-up">
          <div class="step-featured-badge">Our Speciality</div>
          <div class="step-number">03</div>
          <div class="step-icon">✈</div>
          <div class="step-content">
            <h3>Execution & Customs Clearance</h3>
            <p class="step-time">Real-time · Active management · 100% compliance</p>
            <p class="step-desc">This is where most forwarders fail — and where we excel. Our Dubai Cargo Village location gives us direct access to customs officers, airline cargo managers, and port authorities. Problems are resolved before they become delays.</p>
            <ul class="step-list">
              <li>Cargo collection and DCV check-in managed</li>
              <li>UAE Customs clearance — 100% compliance record</li>
              <li>Flight/vessel monitoring with proactive updates</li>
              <li>Destination pre-clearance where applicable</li>
              <li>Real-time status updates to you throughout</li>
            </ul>
            <div class="step-guarantee">
              <span class="guarantee-tag">🏆 100% UAE customs compliance since 2008</span>
            </div>
          </div>
        </div>

        <div class="step-connector fade-up">
          <div class="connector-line"></div>
          <div class="connector-arrow">↓</div>
        </div>

        <!-- Step 4 -->
        <div class="step-card fade-up">
          <div class="step-number">04</div>
          <div class="step-icon">📦</div>
          <div class="step-content">
            <h3>Delivery & Confirmation</h3>
            <p class="step-time">On time · Documented · Closed loop</p>
            <p class="step-desc">Delivery isn't the end of our involvement — it's the final confirmation that everything went exactly as planned. We follow up on every shipment until you confirm receipt and satisfaction.</p>
            <ul class="step-list">
              <li>Last-mile delivery coordination</li>
              <li>Destination customs clearance support</li>
              <li>Proof of delivery documentation</li>
              <li>Post-shipment review and feedback</li>
              <li>Relationship continues — we're here for the next one</li>
            </ul>
            <div class="step-guarantee">
              <span class="guarantee-tag">✓ Delivery confirmed before file is closed</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- TIMELINE VISUAL -->
  <section class="timeline-section fade-up">
    <div class="container">
      <div class="section-header-centered">
        <p class="eyebrow">Typical Timelines</p>
        <h2 class="timeline-title">What to Expect — By Service</h2>
      </div>
      <div class="timeline-grid">
        <div class="timeline-card">
          <div class="timeline-icon">✈</div>
          <h3>Air Freight</h3>
          <div class="timeline-steps">
            <div class="tl-step">
              <span class="tl-label">Quote</span>
              <span class="tl-time">Same day</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Booking & docs</span>
              <span class="tl-time">24–48 hrs</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">UAE to UK</span>
              <span class="tl-time">7–9 hrs flight</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">UAE to Europe</span>
              <span class="tl-time">6–10 hrs flight</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">UAE to USA</span>
              <span class="tl-time">14–16 hrs flight</span>
            </div>
          </div>
          <a href="/services/air-freight" class="timeline-cta">Air Freight Details →</a>
        </div>

        <div class="timeline-card">
          <div class="timeline-icon">🚢</div>
          <h3>Sea Freight</h3>
          <div class="timeline-steps">
            <div class="tl-step">
              <span class="tl-label">Quote</span>
              <span class="tl-time">Same day</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Booking & docs</span>
              <span class="tl-time">2–3 days</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Jebel Ali to Felixstowe</span>
              <span class="tl-time">18–22 days</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Jebel Ali to Rotterdam</span>
              <span class="tl-time">16–20 days</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Jebel Ali to Jakarta</span>
              <span class="tl-time">12–16 days</span>
            </div>
          </div>
          <a href="/services/sea-freight" class="timeline-cta">Sea Freight Details →</a>
        </div>

        <div class="timeline-card">
          <div class="timeline-icon">📋</div>
          <h3>Customs Clearance</h3>
          <div class="timeline-steps">
            <div class="tl-step">
              <span class="tl-label">Document review</span>
              <span class="tl-time">Same day</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Declaration filing</span>
              <span class="tl-time">24 hrs</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Green channel</span>
              <span class="tl-time">4–8 hrs</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Yellow channel</span>
              <span class="tl-time">1–2 days</span>
            </div>
            <div class="tl-step">
              <span class="tl-label">Red channel</span>
              <span class="tl-time">2–5 days</span>
            </div>
          </div>
          <a href="/services/customs-clearance" class="timeline-cta">Customs Details →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT SETS US APART -->
  <section class="differentiators-section fade-up">
    <div class="container diff-grid">
      <div class="diff-content">
        <p class="eyebrow">Why Our Process Works</p>
        <h2 class="diff-title">Inside Dubai Cargo Village. Inside the System.</h2>
        <p class="diff-body">Most freight forwarders manage your cargo remotely — phone calls to carriers, emails to customs brokers, escalations when things go wrong. We operate differently.</p>
        <p class="diff-body">Our team works from Office 2056-A, Entrance 4, Dubai Cargo Village. We walk the same corridors as the customs officers. We know the cargo managers at Emirates SkyCargo by name. When a problem arises — and in freight, problems always arise — we resolve it in minutes, not days.</p>
        <div class="diff-items">
          <div class="diff-item">
            <span class="diff-icon">🎯</span>
            <div>
              <strong>One specialist, start to finish</strong>
              <p>No handoffs. No call centres. The person who quotes your shipment is the person who clears it through customs.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="diff-icon">📞</span>
            <div>
              <strong>Proactive communication</strong>
              <p>We update you before you ask. Flight delays, customs queries, documentation issues — you hear from us first.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="diff-icon">🔒</span>
            <div>
              <strong>Zero tolerance on compliance</strong>
              <p>Every HS code verified. Every document checked. 17 years and not a single UAE customs penalty.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="diff-icon">💰</span>
            <div>
              <strong>What you're quoted is what you pay</strong>
              <p>Fully itemised quotes. No surprises at delivery. No renegotiations mid-shipment.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="diff-stats fade-up">
        <div class="diff-stat">
          <strong>17+</strong>
          <span>Years at Dubai Cargo Village</span>
        </div>
        <div class="diff-stat">
          <strong>200+</strong>
          <span>UAE exporters served</span>
        </div>
        <div class="diff-stat diff-stat--gold">
          <strong>100%</strong>
          <span>UAE customs compliance record</span>
        </div>
        <div class="diff-stat">
          <strong>24hr</strong>
          <span>Maximum quote response time</span>
        </div>
        <div class="diff-stat">
          <strong>10+</strong>
          <span>Clients with us over a decade</span>
        </div>
        <div class="diff-stat">
          <strong>0</strong>
          <span>Customs penalties since 2008</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="process-cta-section fade-up">
    <div class="container process-cta-inner">
      <div>
        <h2>Ready to start your first shipment?</h2>
        <p>Tell us about your cargo. We'll handle everything else.</p>
      </div>
      <div class="process-cta-btns">
        <a href="/contact" class="process-cta-primary">Get a Free Quote</a>
        <a href="https://wa.me/971552572837?text=Hello%20UKF%2C%20I%27d%20like%20to%20discuss%20a%20shipment." target="_blank" rel="noopener" class="process-cta-wa">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "UKF Services Freight Forwarding Process",
    "description": "Step-by-step freight forwarding process from consultation to delivery",
    "totalTime": "PT24H",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Initial Consultation", "text": "Detailed needs assessment to understand your cargo, destination, timeline, and budget. Same-day response guaranteed." },
      { "@type": "HowToStep", "position": 2, "name": "Route Planning & Booking", "text": "Design the optimal route, select carriers, prepare and verify all documentation, file UAE Customs export declaration." },
      { "@type": "HowToStep", "position": 3, "name": "Execution & Customs Clearance", "text": "Cargo collection, UAE Customs clearance with 100% compliance record, real-time tracking and proactive updates." },
      { "@type": "HowToStep", "position": 4, "name": "Delivery & Confirmation", "text": "Last-mile delivery coordination, proof of delivery, post-shipment review and follow-up." }
    ]
  })}</script>

</PageLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }
  .section-header-centered { text-align: center; margin-bottom: 48px; }

  /* HERO */
  .process-hero {
    background: linear-gradient(135deg, var(--navy) 0%, #0f2a50 100%);
    padding: 100px 0 72px;
    text-align: center;
  }
  .process-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .process-subtitle {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    max-width: 600px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }
  .process-hero-proof {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .process-hero-proof span { font-size: 13px; color: rgba(255,255,255,0.6); }

  /* STEPS */
  .steps-section { padding: 80px 0; background: var(--white); }
  .steps-intro { text-align: center; margin-bottom: 64px; }
  .steps-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    color: var(--navy);
    margin-bottom: 16px;
  }
  .steps-subtitle {
    font-size: 16px;
    color: var(--gray-600);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .steps-grid {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 16px;
    padding: 40px;
    display: grid;
    grid-template-columns: 60px 48px 1fr;
    gap: 24px;
    align-items: start;
    position: relative;
    transition: box-shadow 0.25s, border-color 0.25s;
  }
  .step-card:hover {
    box-shadow: 0 16px 48px rgba(10,22,40,0.08);
    border-color: rgba(201,168,76,0.3);
  }
  .step-card--featured {
    border-color: var(--gold);
    background: linear-gradient(135deg, #fffdf5 0%, #fff 100%);
    box-shadow: 0 8px 32px rgba(201,168,76,0.1);
  }
  .step-featured-badge {
    position: absolute;
    top: -12px;
    left: 40px;
    background: var(--gold);
    color: var(--navy);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
  }
  .step-number {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 800;
    color: var(--gray-200);
    line-height: 1;
    padding-top: 4px;
  }
  .step-card--featured .step-number { color: rgba(201,168,76,0.3); }
  .step-icon { font-size: 32px; padding-top: 4px; }
  .step-content h3 {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .step-time {
    font-size: 12px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 14px;
    display: block;
  }
  .step-desc {
    font-size: 14px;
    color: var(--gray-600);
    line-height: 1.75;
    margin-bottom: 16px;
  }
  .step-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }
  .step-list li {
    font-size: 13px;
    color: var(--gray-600);
    padding-left: 20px;
    position: relative;
    line-height: 1.5;
  }
  .step-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 700;
  }
  .step-guarantee { }
  .guarantee-tag {
    display: inline-block;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.2);
    color: var(--gold);
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 20px;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
    gap: 4px;
  }
  .connector-line {
    width: 2px;
    height: 24px;
    background: linear-gradient(to bottom, var(--gold), rgba(201,168,76,0.3));
  }
  .connector-arrow { color: var(--gold); font-size: 18px; }

  @media (max-width: 640px) {
    .step-card { grid-template-columns: 40px 1fr; }
    .step-icon { display: none; }
  }

  /* TIMELINE */
  .timeline-section { padding: 80px 0; background: var(--off-white); border-top: 1px solid var(--gray-200); }
  .timeline-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 34px);
    color: var(--navy);
    margin-bottom: 8px;
  }
  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 900px) { .timeline-grid { grid-template-columns: 1fr; } }

  .timeline-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    padding: 28px;
    transition: box-shadow 0.25s, border-color 0.25s;
  }
  .timeline-card:hover { box-shadow: 0 8px 32px rgba(10,22,40,0.08); border-color: var(--gold); }
  .timeline-icon { font-size: 32px; margin-bottom: 12px; }
  .timeline-card h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--navy);
    margin-bottom: 20px;
  }
  .timeline-steps { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
  .tl-step {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: var(--gray-100);
    border-radius: 6px;
    font-size: 13px;
  }
  .tl-label { color: var(--gray-600); }
  .tl-time { color: var(--navy); font-weight: 700; }
  .timeline-cta {
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
    transition: color 0.2s;
  }
  .timeline-cta:hover { color: var(--navy); }

  /* DIFFERENTIATORS */
  .differentiators-section { padding: 80px 0; background: var(--white); }
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 1024px) { .diff-grid { grid-template-columns: 1fr; } }
  .diff-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 34px);
    color: var(--navy);
    margin-bottom: 16px;
    line-height: 1.25;
  }
  .diff-body { font-size: 15px; color: var(--gray-600); line-height: 1.75; margin-bottom: 14px; }
  .diff-items { display: flex; flex-direction: column; gap: 20px; margin-top: 28px; }
  .diff-item { display: flex; gap: 16px; align-items: flex-start; }
  .diff-icon { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
  .diff-item strong { display: block; font-size: 15px; color: var(--navy); margin-bottom: 4px; }
  .diff-item p { font-size: 13px; color: var(--gray-600); line-height: 1.6; margin: 0; }

  .diff-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .diff-stat {
    background: var(--off-white);
    border: 1px solid var(--gray-200);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    transition: border-color 0.2s;
  }
  .diff-stat:hover { border-color: var(--gold); }
  .diff-stat--gold {
    background: linear-gradient(135deg, #fffdf5 0%, #fff8e6 100%);
