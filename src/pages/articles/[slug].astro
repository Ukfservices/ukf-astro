---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { env } from 'cloudflare:workers';
export const prerender = false;

const { slug } = Astro.params;

let article = null;
let relatedArticles = [];
let error = null;

try {
  const db = env.ukf_insights_db as unknown as D1Database;

  const result = await db.prepare(
    'SELECT * FROM articles WHERE slug = ? LIMIT 1'
  ).bind(slug).first();

  if (!result) {
    return Astro.redirect('/insights', 302);
  }

  article = result;
// Strip legacy navigation metadata from content
if (article.content) {
  let c = article.content as string;
  // Remove "Back to Insights" link
  c = c.replace(/<a[^>]*>Back to Insights<\/a>/gi, '');
  // Remove legacy meta row (author/date/read time line at top)
  c = c.replace(/UKF Operations Team[^<]*/gi, '');
  // Remove any leading empty paragraphs
  c = c.replace(/^(<p>\s*<\/p>)+/gi, '');
  article = { ...article, content: c };
}
  // Related articles — same category, exclude current
  const related = await db.prepare(
    'SELECT id, title, slug, excerpt, category, image_url, read_time, published_date FROM articles WHERE category = ? AND slug != ? ORDER BY published_date DESC LIMIT 3'
  ).bind(article.category, slug).all();

  relatedArticles = related.results || [];

  // Fallback: if fewer than 3 related, fill with recent articles
  if (relatedArticles.length < 3) {
    const needed = 3 - relatedArticles.length;
    const existingSlugs = [slug, ...relatedArticles.map((a: any) => a.slug)];
    const placeholders = existingSlugs.map(() => '?').join(',');
    const fallback = await db.prepare(
      `SELECT id, title, slug, excerpt, category, image_url, read_time, published_date FROM articles WHERE slug NOT IN (${placeholders}) ORDER BY published_date DESC LIMIT ?`
    ).bind(...existingSlugs, needed).all();
    relatedArticles = [...relatedArticles, ...(fallback.results || [])];
  }

} catch (e: any) {
  error = e.message;
}

// Format date
function formatDate(dateStr: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-GB', {
      day: 'numeric', month: 'long', year: 'numeric'
    });
  } catch { return dateStr; }
}

// Category colour mapping
function getCategoryColor(cat: string) {
  const map: Record<string, string> = {
    'Air Freight': '#3b82f6',
    'Sea Freight': '#0ea5e9',
    'Customs': '#8b5cf6',
    'Trade Corridors': '#10b981',
    'Market Intelligence': '#f59e0b',
    'Cargo Journeys': '#e63946',
    'Indonesia': '#10b981',
  };
  return map[cat] || '#c9a84c';
}

const pageTitle = article ? `${article.title} | UKF Services` : 'Article | UKF Services';
const pageDesc = article?.excerpt as string || '';
const pageImage = article?.image_url as string || '/images/ukf-og-default.jpg';
---

<ArticleLayout title={pageTitle} description={pageDesc} image={pageImage}>

  {error && (
    <div style="padding:120px 24px;text-align:center;color:#e63946;">
      <p>Error loading article: {error}</p>
    </div>
  )}

  {article && (
    <>
      <!-- HERO -->
      <section class="article-hero" style={`background-image: url('${article.image_url || '/images/cargo-hero.jpg'}')`}>
        <div class="hero-overlay"></div>
        <div class="hero-content container">
          <div class="hero-meta">
            <span class="category-pill" style={`background:${getCategoryColor(article.category as string)}`}>
              {article.category}
            </span>
            {Boolean(article.featured) && <span class="featured-badge">Featured</span>}
          </div>
          <h1 class="hero-title">{article.title}</h1>
          <div class="hero-byline">
            <div class="byline-author">
              <div class="author-avatar">MS</div>
              <div>
                <span class="author-name">Mirza Salim Baig</span>
                <span class="author-role">CEO, UKF Services</span>
              </div>
            </div>
            <div class="byline-stats">
              <span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                {article.read_time}
              </span>
              <span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
                {formatDate(article.published_date as string)}
              </span>
              {Boolean(article.views) && (
                <span>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
                  {article.views} views
                </span>
              )}
            </div>
          </div>
        </div>
      </section>

      <!-- ARTICLE BODY -->
      <div class="article-wrapper">
        <div class="container article-container">

          <!-- SIDEBAR TOC -->
          <aside class="toc-sidebar" id="toc-sidebar">
            <div class="toc-inner" id="toc-inner">
              <p class="toc-label">In this article</p>
              <nav id="toc-nav" aria-label="Table of contents">
                <!-- Populated by JS -->
                <p class="toc-loading">Loading...</p>
              </nav>
              <div class="toc-share">
                <p class="toc-label" style="margin-top:24px;">Share</p>
                <div class="toc-share-btns">
                  <a id="toc-li-share" href="#" target="_blank" rel="noopener" class="toc-share-btn toc-share-btn--li" aria-label="Share on LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                  <a id="toc-wa-share" href="#" target="_blank" rel="noopener" class="toc-share-btn toc-share-btn--wa" aria-label="Share on WhatsApp">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </aside>

          <!-- MAIN CONTENT -->
          <article class="article-body">

            <!-- Standfirst -->
            {article.excerpt && (
              <p class="standfirst">{article.excerpt}</p>
            )}

            <!-- Article Content from D1 -->
            <div class="article-content" set:html={article.content} />

            <!-- Mid-article CTA -->
            <div class="mid-cta fade-up">
              <div class="mid-cta-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28"><path d="M20 4H4c-1.103 0-2 .897-2 2v12c0 1.103.897 2 2 2h16c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2zm0 2v.511l-8 6.223-8-6.222V6h16zM4 18V9.044l7.386 5.745a.994.994 0 001.228 0L20 9.044 20.002 18H4z"/></svg>
              </div>
              <div class="mid-cta-text">
                <h3>Shipping on this corridor?</h3>
                <p>Get a tailored freight quote from UKF's specialists. Same-day response, no obligation.</p>
              </div>
              <div class="mid-cta-actions">
                <a href="/contact" class="mid-cta-btn-primary">Get a Quote</a>
                <a href="https://wa.me/971552572837" target="_blank" rel="noopener" class="mid-cta-btn-wa">WhatsApp</a>
              </div>
            </div>

            <!-- Author Bio -->
            <div class="author-bio fade-up">
              <div class="author-bio-avatar">MS</div>
              <div class="author-bio-content">
                <div class="author-bio-header">
                  <div>
                    <h3 class="author-bio-name">Mirza Salim Baig</h3>
                    <p class="author-bio-role">Chief Executive Officer, UKF Sea & Air Cargo Services</p>
                  </div>
                  <div class="author-bio-badge">25+ Years</div>
                </div>
                <p class="author-bio-text">
                  Mirza Salim Baig has led UKF Services from Dubai Cargo Village since 2008, building one of the UAE's most trusted specialist freight operations. With over 25 years in international logistics, he brings direct expertise across air freight, sea freight, and UAE customs clearance — personally overseeing complex shipments for 200+ UAE exporters across global trade corridors.
                </p>
              </div>
            </div>

            <!-- Share Buttons -->
            <div class="share-section fade-up">
              <p class="share-label">Share this article</p>
              <div class="share-buttons">
                <a id="li-share" href="#" target="_blank" rel="noopener" class="share-btn share-btn--linkedin">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  Share on LinkedIn
                </a>
                <a id="wa-share" href="#" target="_blank" rel="noopener" class="share-btn share-btn--whatsapp">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Share on WhatsApp
                </a>
              </div>
            </div>

          </article>
        </div>

        <!-- RELATED ARTICLES -->
        {relatedArticles.length > 0 && (
          <section class="related-section fade-up">
            <div class="container">
              <div class="related-header">
                <h2 class="related-title">Related Intelligence</h2>
                <a href="/insights" class="related-all">View all articles →</a>
              </div>
              <div class="related-grid">
                {relatedArticles.map((rel: any) => (
                  <a href={`/articles/${rel.slug}`} class="related-card">
                    <div class="related-card-image" style={`background-image:url('${rel.image_url || '/images/cargo-hero.jpg'}')`}>
                      <span class="related-card-category" style={`background:${getCategoryColor(rel.category)}`}>{rel.category}</span>
                    </div>
                    <div class="related-card-body">
                      <h3 class="related-card-title">{rel.title}</h3>
                      <p class="related-card-excerpt">{rel.excerpt?.substring(0, 100)}...</p>
                      <div class="related-card-meta">
                        <span>{rel.read_time}</span>
                        <span class="related-card-link">Read →</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>
        )}

      </div>

      <!-- JSON-LD -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": article.title,
        "description": article.excerpt,
        "image": `https://ukfservices.com${article.image_url}`,
        "datePublished": article.published_date,
        "author": {
          "@type": "Person",
          "name": "Mirza Salim Baig",
          "jobTitle": "CEO",
          "worksFor": { "@type": "Organization", "name": "UKF Services" }
        },
        "publisher": {
          "@type": "Organization",
          "name": "UKF Services",
          "url": "https://ukfservices.com"
        },
        "mainEntityOfPage": `https://ukfservices.com/articles/${article.slug}`
      })} />

    </>
  )}

  <!-- TOC + Share JS -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var pageUrl = encodeURIComponent(window.location.href);
      var pageTitle = encodeURIComponent(document.title);

      // Share links
      var liShare = document.getElementById('li-share');
      var waShare = document.getElementById('wa-share');
      var tocLiShare = document.getElementById('toc-li-share');
      var tocWaShare = document.getElementById('toc-wa-share');

      var liUrl = 'https://www.linkedin.com/shareArticle?mini=true&url=' + pageUrl + '&title=' + pageTitle;
      var waUrl = 'https://wa.me/?text=' + pageTitle + '%20' + pageUrl;

      if (liShare) liShare.href = liUrl;
      if (waShare) waShare.href = waUrl;
      if (tocLiShare) tocLiShare.href = liUrl;
      if (tocWaShare) tocWaShare.href = waUrl;

      // Build TOC from article headings
      var content = document.querySelector('.article-content');
      var tocNav = document.getElementById('toc-nav');
      if (content && tocNav) {
        var headings = content.querySelectorAll('h2, h3');
        if (headings.length > 0) {
          tocNav.innerHTML = '';
          var list = document.createElement('ul');
          list.className = 'toc-list';
          headings.forEach(function(h, i) {
            var id = 'heading-' + i;
            h.id = id;
            var li = document.createElement('li');
            li.className = h.tagName === 'H3' ? 'toc-item toc-item--h3' : 'toc-item';
            var a = document.createElement('a');
            a.href = '#' + id;
            a.textContent = h.textContent;
            a.className = 'toc-link';
            a.addEventListener('click', function(e) {
              e.preventDefault();
              h.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
            li.appendChild(a);
            list.appendChild(li);
          });
          tocNav.appendChild(list);

          // Highlight active heading on scroll
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              var id = entry.target.id;
              var link = tocNav.querySelector('a[href="#' + id + '"]');
              if (link) {
                if (entry.isIntersecting) {
                  tocNav.querySelectorAll('.toc-link').forEach(function(l) { l.classList.remove('active'); });
                  link.classList.add('active');
                }
              }
            });
          }, { rootMargin: '-20% 0px -70% 0px' });
          headings.forEach(function(h) { observer.observe(h); });

        } else {
          tocNav.innerHTML = '<p class="toc-empty">No sections found</p>';
        }
      }

      // Sticky TOC
      var tocSidebar = document.getElementById('toc-sidebar');
      var tocInner = document.getElementById('toc-inner');
      if (tocSidebar && tocInner) {
        var sidebarTop = tocSidebar.getBoundingClientRect().top + window.scrollY;
        window.addEventListener('scroll', function() {
          if (window.scrollY > sidebarTop - 100) {
            tocInner.classList.add('sticky');
          } else {
            tocInner.classList.remove('sticky');
          }
        }, { passive: true });
      }
    });
  </script>

</ArticleLayout>

<style is:global>
  /* Article content styles — must be global for set:html */
  .article-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 700;
    color: #0a1628;
    margin: 48px 0 20px;
    line-height: 1.3;
    padding-bottom: 12px;
    border-bottom: 2px solid #f0e6c8;
  }
  .article-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 600;
    color: #0a1628;
    margin: 36px 0 14px;
    line-height: 1.4;
  }
  .article-content h4 {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #0a1628;
    margin: 28px 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .article-content p {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.85;
    color: #2a2a3e;
    margin-bottom: 24px;
  }
  .article-content ul, .article-content ol {
    margin: 0 0 28px 24px;
  }
  .article-content li {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.8;
    color: #2a2a3e;
    margin-bottom: 8px;
  }
  .article-content ul li::marker { color: #c9a84c; }
  .article-content ol li::marker { color: #c9a84c; font-weight: 700; }
  .article-content strong { color: #0a1628; font-weight: 700; }
  .article-content em { font-style: italic; color: #444; }
  .article-content a { color: #c9a84c; text-decoration: underline; transition: color 0.2s; }
  .article-content a:hover { color: #0a1628; }
  .article-content blockquote {
    margin: 40px 0;
    padding: 28px 32px;
    background: linear-gradient(135deg, #fdf8ee 0%, #faf4e4 100%);
    border-left: 4px solid #c9a84c;
    border-radius: 0 8px 8px 0;
    position: relative;
  }
  .article-content blockquote::before {
    content: '"';
    position: absolute;
    top: -10px; left: 20px;
    font-family: 'Playfair Display', serif;
    font-size: 72px;
    color: #c9a84c;
    opacity: 0.3;
    line-height: 1;
  }
  .article-content blockquote p {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    line-height: 1.6;
    color: #0a1628;
    font-style: italic;
    margin: 0;
  }
  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 32px 0;
    font-size: 14px;
  }
  .article-content th {
    background: #0a1628;
    color: #c9a84c;
    padding: 12px 16px;
    text-align: left;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .article-content td {
    padding: 12px 16px;
    border-bottom: 1px solid #e8e8e8;
    color: #333;
    font-family: 'Inter', sans-serif;
  }
  .article-content tr:nth-child(even) td { background: #f8f6f0; }
  .article-content img {
    width: 100%;
    border-radius: 8px;
    margin: 32px 0;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }
  .article-content hr {
    border: none;
    border-top: 2px solid #f0e6c8;
    margin: 48px 0;
  }
</style>

<style>
  /* HERO */
  .article-hero {
    position: relative;
    min-height: 70vh;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    display: flex;
    align-items: flex-end;
  }
  @media (max-width: 768px) {
    .article-hero { background-attachment: scroll; min-height: 55vh; }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10,22,40,0.3) 0%,
